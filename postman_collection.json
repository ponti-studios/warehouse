            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Grocery Store\",\n    \"amount\": -50.00,\n    \"account\": \"Checking\",\n    \"category\": \"Food\",\n    \"date\": \"2024-01-15\",\n    \"note\": \"Weekly groceries\"\n}"
            }
          },
          "response": []
