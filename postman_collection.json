        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Checking\",\n    \"type\": \"CHECKING\",\n    \"currency\": \"USD\"\n}"
