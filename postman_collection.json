            "body": {
              "mode": "raw",
              "raw": "{\n    \"transactions\": [\n        {\n            \"name\": \"Transaction 1\",\n            \"amount\": -10.00,\n            \"account\": \"Checking\",\n            \"date\": \"2024-01-01\"\n        },\n        {\n            \"name\": \"Transaction 2\",\n            \"amount\": -20.00,\n            \"account\": \"Checking\",\n            \"date\": \"2024-01-02\"\n        },\n        {\n            \"name\": \"Transaction 3\",\n            \"amount\": -30.00,\n            \"account\": \"Checking\",\n            \"date\": \"2024-01-03\"\n        }\n    ],\n    \"skipDuplicates\": false\n}"
            }
          },
          "response": []
        },
