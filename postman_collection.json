        {
          "name": "Get Transactions with Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions?account=Checking&category=Food&start_date=2024-01-01&end_date=2024-12-31&page=1&per_page=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions"],
              "query": [
                {"key": "account", "value": "Checking"},
                {"key": "category", "value": "Food"},
                {"key": "start_date", "value": "2024-01-01"},
                {"key": "end_date", "value": "2024-12-31"},
                {"key": "page", "value": "1"},
                {"key": "per_page", "value": "20"}
              ]
            }
          },
          "response": []
        },
